          "host": "Host / IP Address",
          "machine_name": "Machine Name",
          "mtconnect_port": "MTConnect Agent Port",
          "mdc_port": "MDC Port",
          "mtconnect_device": "MTConnect Device Name"
        },
        "data_description": {
          "host": "IP address or hostname of the HAAS machine (e.g. 192.168.1.100).",
          "machine_name": "A friendly name for your CNC machine (e.g. HAAS UMC-500).",
          "mtconnect_port": "Port of the MTConnect HTTP agent (default: 5000).",
          "mdc_port": "Port for MDC/Q-command interface (default: 5051). Requires Setting 143 = ON.",
          "mtconnect_device": "MTConnect device name (leave blank to auto-detect first device)."
        }
      }
    },
    "error": {
      "cannot_connect": "Cannot connect to the HAAS machine. Verify the IP address and that MTConnect or MDC (Setting 143) is enabled."
